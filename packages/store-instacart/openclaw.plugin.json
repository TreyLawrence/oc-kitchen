{
  "id": "oc-kitchen-instacart",
  "name": "OC Kitchen — Instacart",
  "description": "Automated grocery ordering from any Instacart-supported retailer via computer-use agent",
  "version": "0.1.0",
  "configSchema": {
    "type": "object",
    "properties": {
      "email": {
        "type": "string",
        "description": "Instacart account email"
      },
      "password": {
        "type": "string",
        "description": "Instacart account password"
      },
      "defaultStore": {
        "type": "string",
        "description": "Default Instacart retailer slug (e.g., \"wegmans\", \"costco\")",
        "default": "wegmans"
      }
    },
    "additionalProperties": false
  },
  "skills": [
    "skills/instacart-ordering"
  ]
}
